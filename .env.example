# =============================================================
# VOICE AI PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================================

# -------------------------------------------------------------
# PLATFORM
# -------------------------------------------------------------
PLATFORM_SECRET_KEY=changeme-use-a-long-random-string
ENVIRONMENT=development
# Options: development | staging | production
DEBUG=true
LOG_LEVEL=info

# -------------------------------------------------------------
# API GATEWAY (port 8000)
# -------------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8006
RATE_LIMIT_PER_MINUTE=60

# -------------------------------------------------------------
# POSTGRESQL
# -------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=voiceai
POSTGRES_USER=voiceai_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://voiceai_user:changeme@postgres:5432/voiceai

# -------------------------------------------------------------
# REDIS
# -------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# -------------------------------------------------------------
# LIVEKIT (port 7880 / 7881)
# -------------------------------------------------------------
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_WS_URL=ws://localhost:7880

# -------------------------------------------------------------
# OLLAMA (port 11434)
# -------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3.5:cloud
OLLAMA_CODER_MODEL=qwen3-coder-next:cloud
OLLAMA_LOCAL_FALLBACK_MODEL=gpt-oss:20b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.3

# -------------------------------------------------------------
# SPEECH TO TEXT — faster-whisper
# -------------------------------------------------------------
WHISPER_MODEL_SIZE=base
# Options: tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu
# Options: cpu | cuda
WHISPER_COMPUTE_TYPE=int8
# Options: int8 | float16 | float32
WHISPER_LANGUAGE=en

# -------------------------------------------------------------
# TEXT TO SPEECH — Piper TTS
# -------------------------------------------------------------
PIPER_MODEL_PATH=/models/piper/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=/models/piper/en_US-lessac-medium.onnx.json
PIPER_SAMPLE_RATE=22050

# -------------------------------------------------------------
# KNOWLEDGE SERVICE (port 8003)
# -------------------------------------------------------------
KNOWLEDGE_SERVICE_URL=http://knowledge-service:8003
POCKETFLOW_TOP_K_CHUNKS=5
POCKETFLOW_CHUNK_SIZE=512
POCKETFLOW_CHUNK_OVERLAP=64
KNOWLEDGE_CACHE_TTL_SECONDS=3600

# -------------------------------------------------------------
# CRAWLER SERVICE (port 8004)
# -------------------------------------------------------------
CRAWLER_SERVICE_URL=http://crawler-service:8004
CRAWLER_MAX_PAGES=100
CRAWLER_MAX_DEPTH=3
CRAWLER_DELAY_SECONDS=1
CRAWLER_TIMEOUT_SECONDS=10
CRAWLER_USER_AGENT=VoiceAIBot/1.0

# -------------------------------------------------------------
# TENANT SERVICE (port 8005)
# -------------------------------------------------------------
TENANT_SERVICE_URL=http://tenant-service:8005
API_KEY_LENGTH=32
API_KEY_HASH_ROUNDS=12

# -------------------------------------------------------------
# VOICE SERVICE (port 8001)
# -------------------------------------------------------------
VOICE_SERVICE_URL=http://voice-service:8001
VOICE_SESSION_TIMEOUT_SECONDS=300
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# -------------------------------------------------------------
# LLM SERVICE (port 8002)
# -------------------------------------------------------------
LLM_SERVICE_URL=http://llm-service:8002
LLM_SYSTEM_PROMPT_GUARDRAIL=Answer only using the provided context. Do not use outside knowledge. If the answer is not in the context, say you don't know.
LLM_MAX_CONTEXT_CHUNKS=5
LLM_STREAM_RESPONSES=true

# -------------------------------------------------------------
# WEB WIDGET SERVICE (port 8006)
# -------------------------------------------------------------
WIDGET_SERVICE_URL=http://web-widget:8006
WIDGET_ALLOWED_DOMAINS=*
# Restrict to specific domains in production e.g: example.com,shop.example.com

# -------------------------------------------------------------
# SECURITY
# -------------------------------------------------------------
JWT_SECRET_KEY=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
BCRYPT_ROUNDS=12

# -------------------------------------------------------------
# CELERY TASK QUEUE
# -------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=4

